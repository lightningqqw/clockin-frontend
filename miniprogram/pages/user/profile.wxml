<!-- 个人中心页 - 完全还原 Figma 设计稿 -->
<view class="profile-page">
  <!-- 顶部导航栏 -->
  <view class="header-bar" style="height: {{navBarHeight}}px; padding-top: {{statusBarHeight}}px;">
    <view class="back-icon" bind:tap="goBack">
      <view class="arrow-left"></view>
    </view>
    <view class="header-title">每日打卡</view>
    <view class="header-right"></view>
  </view>

  <view class="page-content" style="padding-top: {{navBarHeight + 16}}px;">
    <!-- 用户信息区 -->
    <view class="profile-header">
      <view class="avatar-wrapper">
        <view class="avatar-border">
          <image
            wx:if="{{userInfo}}"
            class="user-avatar"
            src="{{userInfo.avatarUrl}}"
            mode="aspectFill"
          />
          <image
            wx:else
            class="user-avatar"
            src="/assets/default-avatar.png"
            mode="aspectFill"
          />
        </view>
        <view class="edit-badge" bind:tap="editProfile">
          <text class="edit-icon">✓</text>
        </view>
      </view>
      <view class="user-name">{{userInfo.nickname || '未设置昵称'}}</view>
      <view class="user-bio">{{userInfo.bio || '点击编辑个人资料'}}</view>
    </view>

    <!-- 统计数据卡片 -->
    <view class="stats-grid">
      <view class="stat-card" bind:tap="goToStats">
        <view class="stat-label">连续打卡</view>
        <view class="stat-value-row">
          <text class="stat-number">{{stats.streakDays || 0}}</text>
          <text class="stat-unit">天</text>
        </view>
      </view>
      <view class="stat-card" bind:tap="goToThemes">
        <view class="stat-label">完成习惯</view>
        <view class="stat-value-row">
          <text class="stat-number">{{stats.totalCheckins || 0}}</text>
          <text class="stat-unit">个</text>
        </view>
      </view>
    </view>

    <!-- 功能菜单列表 -->
    <view class="menu-section">
      <view class="menu-title">账户与设置</view>
      <view class="menu-card">
        <!-- 我的通知 -->
        <view class="menu-item" bind:tap="goToNotifications">
          <view class="menu-left">
            <view class="menu-icon-wrapper">
              <text class="menu-icon">🔔</text>
              <view wx:if="{{unreadCount > 0}}" class="menu-badge"></view>
            </view>
            <text class="menu-text">我的通知</text>
          </view>
          <view class="menu-arrow">
            <text>›</text>
          </view>
        </view>

        <!-- 数据统计 -->
        <view class="menu-item" bind:tap="goToStats">
          <view class="menu-left">
            <view class="menu-icon-wrapper">
              <text class="menu-icon">📊</text>
            </view>
            <text class="menu-text">数据统计</text>
          </view>
          <view class="menu-arrow">
            <text>›</text>
          </view>
        </view>

        <!-- 我的主题 -->
        <view class="menu-item" bind:tap="goToThemes">
          <view class="menu-left">
            <view class="menu-icon-wrapper">
              <text class="menu-icon">🎯</text>
            </view>
            <text class="menu-text">我的主题</text>
          </view>
          <view class="menu-arrow">
            <text>›</text>
          </view>
        </view>

        <!-- 设置 -->
        <view class="menu-item" bind:tap="goToSettings">
          <view class="menu-left">
            <view class="menu-icon-wrapper">
              <text class="menu-icon">⚙️</text>
            </view>
            <text class="menu-text">设置</text>
          </view>
          <view class="menu-arrow">
            <text>›</text>
          </view>
        </view>

        <!-- 关于 -->
        <view class="menu-item" bind:tap="showAbout">
          <view class="menu-left">
            <view class="menu-icon-wrapper">
              <text class="menu-icon">ℹ️</text>
            </view>
            <text class="menu-text">关于</text>
          </view>
          <view class="menu-arrow">
            <text>›</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-btn" bind:tap="logout">
      <text>退出登录</text>
    </view>
  </view>
</view>
