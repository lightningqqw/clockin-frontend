<!-- 个人中心页 -->
<view class="profile-page">
  <navbar title="我的" showBack="{{false}}"></navbar>

  <view class="page-content">
    <!-- 用户信息卡片 -->
    <view class="user-profile-card">
      <image class="profile-bg" src="/assets/profile-bg.png" mode="aspectFill" />
      <view class="user-info">
        <image wx:if="{{userInfo}}" class="user-avatar-large" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
        <image wx:else class="user-avatar-large" src="/assets/default-avatar.png" mode="aspectFill" />
        <view class="user-details">
          <view wx:if="{{userInfo}}" class="user-name">{{userInfo.nickname}}</view>
          <view wx:else class="user-name">用户</view>
          <view wx:if="{{userInfo}}" class="user-id">ID: {{userInfo.id}}</view>
          <view wx:else class="user-id">ID: --</view>
        </view>
        <view class="edit-btn" bind:tap="editProfile">
          <text>编辑</text>
        </view>
      </view>
    </view>

    <!-- 统计数据 -->
    <card>
      <view class="stats-grid">
        <view class="stat-item" bind:tap="goToThemes">
          <text class="stat-value">{{stats.totalThemes}}</text>
          <text class="stat-label">参与主题</text>
        </view>
        <view class="stat-item" bind:tap="goToStats">
          <text class="stat-value">{{stats.totalCheckins}}</text>
          <text class="stat-label">总打卡</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{stats.streakDays}}</text>
          <text class="stat-label">连续打卡</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{stats.totalLikes}}</text>
          <text class="stat-label">获赞</text>
        </view>
      </view>
    </card>

    <!-- 功能列表 -->
    <view class="menu-list">
      <view class="menu-item" bind:tap="goToNotifications">
        <text class="menu-icon">🔔</text>
        <text class="menu-text">我的通知</text>
        <view wx:if="{{unreadCount > 0}}" class="badge">{{unreadCount}}</view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bind:tap="goToStats">
        <text class="menu-icon">📊</text>
        <text class="menu-text">数据统计</text>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bind:tap="goToThemes">
        <text class="menu-icon">🎯</text>
        <text class="menu-text">我的主题</text>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bind:tap="goToSettings">
        <text class="menu-icon">⚙️</text>
        <text class="menu-text">设置</text>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bind:tap="showAbout">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-section">
      <custom-button type="danger" size="large" round plain bind:tap="logout">
        退出登录
      </custom-button>
    </view>
  </view>
</view>
