<!-- 创建打卡页 - 完全还原 Figma 设计稿 -->
<view class="create-checkin-page">
  <!-- 顶部导航栏 -->
  <view class="header-bar" style="height: {{navBarHeight}}px; padding-top: {{statusBarHeight}}px;">
    <view class="back-icon" bind:tap="goBack">
      <view class="arrow-left"></view>
    </view>
    <view class="header-title">每日打卡</view>
    <view class="publish-btn" bind:tap="submit">
      <text>发布</text>
    </view>
  </view>

  <view class="page-content" style="padding-top: {{navBarHeight + 16}}px;">
    <!-- 进度指示器 -->
    <view class="progress-indicator">
      <view class="progress-segment active"></view>
      <view class="progress-segment"></view>
      <view class="progress-segment light"></view>
    </view>

    <!-- 页面标题 -->
    <view class="page-header">
      <view class="header-title-text">打卡内容与心情</view>
      <view class="header-desc">记录这一刻的真实感受，赋予习惯灵魂。</view>
    </view>

    <!-- 主卡片 -->
    <view class="main-card">
      <!-- 打卡内容输入 -->
      <view class="content-section">
        <textarea
          class="content-input"
          placeholder="记录今天的打卡内容..."
          value="{{content}}"
          bind:input="onContentChange"
          maxlength="500"
          auto-height
        />
        <view class="word-count">{{contentLength}} / 500</view>
      </view>

      <!-- 图片上传 -->
      <view class="image-section">
        <view class="section-header">
          <text class="section-title">记录瞬间</text>
          <text class="section-limit">最多9张</text>
        </view>
        <view class="image-grid">
          <!-- 已上传图片 -->
          <view
            wx:for="{{images}}"
            wx:key="index"
            class="image-item"
          >
            <image class="uploaded-image" src="{{item}}" mode="aspectFill" bind:tap="previewImage" data-url="{{item}}" />
            <view class="delete-btn" bind:tap="removeImage" data-index="{{index}}">×</view>
          </view>
          <!-- 添加按钮 -->
          <view wx:if="{{images.length < 9}}" class="upload-btn" bind:tap="chooseImage">
            <text class="upload-icon">+</text>
          </view>
          <!-- 占位格子 -->
          <view wx:for="{{3 - (images.length % 3) - (images.length < 9 ? 1 : 0)}}" wx:key="index" class="image-placeholder"></view>
        </view>
      </view>

      <!-- 心情选择 -->
      <view class="mood-section">
        <view class="section-title">此刻心情</view>
        <view class="mood-selector">
          <view
            wx:for="{{moodOptions}}"
            wx:key="value"
            class="mood-item {{mood === item.value ? 'active' : ''}}"
            bind:tap="selectMood"
            data-mood="{{item.value}}"
          >
            <text class="mood-emoji">{{item.emoji}}</text>
          </view>
        </view>
      </view>

      <!-- 位置选择 -->
      <view class="location-section" bind:tap="getLocation">
        <view class="location-left">
          <view class="location-icon-wrapper">
            <text class="location-icon">📍</text>
          </view>
          <view class="location-info">
            <text class="location-title">{{location ? location : '选择位置'}}</text>
            <text wx:if="{{!location}}" class="location-subtitle">让打卡足迹更完整</text>
          </view>
        </view>
        <view class="location-arrow">
          <text>›</text>
        </view>
      </view>
    </view>

    <!-- 快捷按钮区 -->
    <view class="quick-actions">
      <view class="action-btn" bind:tap="generateAI">
        <text class="action-icon">✍️</text>
        <text class="action-text">生成AI灵感</text>
      </view>
      <view class="action-btn" bind:tap="viewHistory">
        <text class="action-icon">📅</text>
        <text class="action-text">查看往日灵感</text>
      </view>
    </view>

    <!-- 上传进度 -->
    <view wx:if="{{submitting && uploadProgress > 0}}" class="upload-progress">
      <text class="progress-text">图片上传中 {{uploadProgress}}%</text>
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{uploadProgress}}%"></view>
      </view>
    </view>
  </view>
</view>
