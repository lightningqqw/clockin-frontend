<!-- 创建主题页 - 完全还原 Figma 设计稿 -->
<view class="create-theme-page">
  <!-- 顶部导航栏 -->
  <view class="header-bar" style="height: {{navBarHeight}}px; padding-top: {{statusBarHeight}}px;">
    <view class="back-icon" bind:tap="goBack">
      <view class="arrow-left"></view>
    </view>
    <view class="header-title">创建主题</view>
    <view class="header-right"></view>
  </view>

  <view class="page-content" style="padding-top: {{navBarHeight + 16}}px;">
    <!-- 页面标题 -->
    <view class="page-header">
      <view class="header-title-text">基本信息</view>
      <view class="header-desc">定义您的习惯仪式。一个好的名字与描述是持久坚持的开始。</view>
    </view>

    <!-- 表单卡片 -->
    <view class="form-card">
      <!-- 主题名称 -->
      <view class="form-group">
        <view class="form-label">
          <text class="label-icon">▱</text>
          <text>主题名称</text>
        </view>
        <input
          class="form-input"
          placeholder="请输入主题名称"
          value="{{form.title}}"
          bind:input="onInputChange"
          data-field="title"
          maxlength="50"
        />
      </view>

      <!-- 主题描述 -->
      <view class="form-group">
        <view class="form-label">
          <text class="label-icon">📝</text>
          <text>主题描述</text>
        </view>
        <textarea
          class="form-textarea"
          placeholder="请输入描述..."
          value="{{form.description}}"
          bind:input="onTextareaChange"
          data-field="description"
          maxlength="500"
        />
      </view>

      <!-- 主题类型 -->
      <view class="form-group">
        <view class="form-label">
          <text class="label-icon">⚙</text>
          <text>主题类型</text>
        </view>
        <view class="type-selector">
          <view
            class="type-option {{form.type === 'simple' ? 'active' : ''}}"
            bind:tap="selectType"
            data-type="simple"
          >
            <view class="type-icon-wrapper simple-icon">
              <text class="type-icon">✓</text>
            </view>
            <view class="type-info">
              <text class="type-name">简单打卡</text>
              <text class="type-desc">快速签到，一键完成</text>
            </view>
            <view class="type-check">
              <view wx:if="{{form.type === 'simple'}}" class="check-icon">✓</view>
            </view>
          </view>
          <view
            class="type-option {{form.type === 'rich' ? 'active' : ''}}"
            bind:tap="selectType"
            data-type="rich"
          >
            <view class="type-icon-wrapper rich-icon">
              <text class="type-icon">📝</text>
            </view>
            <view class="type-info">
              <text class="type-name">富文本打卡</text>
              <text class="type-desc">图文记录，感悟分享</text>
            </view>
            <view class="type-check">
              <view wx:if="{{form.type === 'rich'}}" class="check-icon">✓</view>
            </view>
          </view>
        </view>
      </view>

      <!-- 时间设置 -->
      <view class="form-group">
        <view class="form-label">时间设置</view>
        <view class="time-settings">
          <view class="time-item">
            <text class="time-label">开始日期</text>
            <picker mode="date" value="{{form.startDate}}" bind:change="onDateChange" data-field="startDate">
              <view class="time-value">{{form.startDate}}</view>
            </picker>
          </view>
          <view class="time-item">
            <text class="time-label">结束日期</text>
            <picker mode="date" value="{{form.endDate}}" bind:change="onDateChange" data-field="endDate">
              <view class="time-value">{{form.endDate}}</view>
            </picker>
          </view>
          <view class="time-item">
            <text class="time-label">打卡提醒</text>
            <picker mode="time" value="{{form.reminderTime}}" bind:change="onTimeChange">
              <view class="time-value">{{form.reminderTime || '不提醒'}}</view>
            </picker>
          </view>
          <view class="time-item repeat-item">
            <text class="time-label">重复周期</text>
            <view class="repeat-days">
              <view
                wx:for="{{repeatDays}}"
                wx:key="value"
                class="day-tag {{isDaySelected(item.value) ? 'active' : ''}}"
                bind:tap="toggleRepeatDay"
                data-day="{{item.value}}"
              >{{item.label}}</view>
            </view>
          </view>
        </view>
      </view>

      <!-- 高级设置 -->
      <view class="form-group">
        <view class="form-label">高级设置</view>
        <view class="switch-list">
          <view class="switch-item">
            <text class="switch-label">允许补打卡</text>
            <switch
              checked="{{form.allowSupplement}}"
              bind:change="onSwitchChange"
              data-field="allowSupplement"
              color="#006b1b"
            />
          </view>
          <view class="switch-item">
            <text class="switch-label">公开主题</text>
            <switch
              checked="{{form.isPublic}}"
              bind:change="onSwitchChange"
              data-field="isPublic"
              color="#006b1b"
            />
          </view>
        </view>
      </view>

      <!-- 提交按钮 -->
      <view class="submit-btn" bind:tap="submit">
        <text class="btn-text">{{submitting ? '创建中...' : '创建主题'}}</text>
        <text wx:if="{{!submitting}}" class="btn-arrow">→</text>
      </view>
    </view>
  </view>
</view>
