<!-- 主题详情页 -->
<view class="theme-detail-page">
  <navbar title="主题详情"></navbar>

  <view wx:if="{{loading}}" class="loading-full">
    <loading></loading>
  </view>

  <view wx:else class="page-content">
    <!-- 主题信息卡片 -->
    <view class="theme-header">
      <image wx:if="{{theme.coverImage}}" class="theme-cover" src="{{theme.coverImage}}" mode="aspectFill" />
      <view wx:else class="theme-cover placeholder">
        <text class="cover-icon">🎯</text>
      </view>
      <view class="theme-info-overlay">
        <view class="theme-title">{{theme.title}}</view>
        <view wx:if="{{theme.description}}" class="theme-desc">{{theme.description}}</view>
        <view class="theme-meta">
          <text class="meta-tag">{{theme.type === 'simple' ? '简单打卡' : '富文本打卡'}}</text>
          <text class="meta-tag">{{theme.memberCount || 0}}人参与</text>
        </view>
        <!-- 邀请码显示（仅创建者可见） -->
        <view wx:if="{{isCreator && theme.inviteCode}}" class="invite-code-section" bind:tap="copyInviteCode">
          <text class="invite-label">邀请码：</text>
          <text class="invite-code">{{theme.inviteCode}}</text>
          <text class="invite-hint">点击复制</text>
        </view>
      </view>
    </view>

    <!-- 快捷操作 -->
    <view class="action-bar">
      <view class="action-item" bind:tap="goToCalendar">
        <text class="action-icon">📅</text>
        <text class="action-text">日历</text>
      </view>
      <view class="action-item" bind:tap="showMembers">
        <text class="action-icon">👥</text>
        <text class="action-text">成员</text>
      </view>
      <view class="action-item" bind:tap="showStats">
        <text class="action-icon">📊</text>
        <text class="action-text">统计</text>
      </view>
      <view wx:if="{{isCreator}}" class="action-item" bind:tap="showInviteCode">
        <text class="action-icon">🔗</text>
        <text class="action-text">邀请</text>
      </view>
      <view wx:if="{{isCreator}}" class="action-item delete" bind:tap="deleteTheme">
        <text class="action-icon">🗑️</text>
        <text class="action-text">删除</text>
      </view>
    </view>

    <!-- 日历 -->
    <card title="打卡日历" extra="{{calendar.year}}年{{calendar.month}}月">
      <calendar
        year="{{calendar.year}}"
        month="{{calendar.month}}"
        checkinDates="{{calendar.dates}}"
        streakDays="{{streakDays}}"
        selectedDate="{{selectedDate}}"
        bind:monthChange="onMonthChange"
        bind:dayTap="onDayTap"
      ></calendar>
    </card>

    <!-- 选中日期的打卡详情 -->
    <view wx:if="{{showDateDetail && selectedDate}}" class="date-detail-section">
      <card title="{{selectedDate}} 打卡记录">
        <view class="detail-header">
          <text class="detail-title">{{selectedDate}} 的打卡</text>
          <text class="close-btn" bind:tap="closeDateDetail">✕</text>
        </view>

        <view wx:if="{{selectedCheckins.length === 0}}" class="empty-area">
          <empty title="暂无打卡" description="这一天还没有人打卡"></empty>
        </view>

        <view wx:else class="selected-checkin-list">
          <view
            wx:for="{{selectedCheckins}}"
            wx:key="id"
            class="selected-checkin-item"
            bind:tap="goToSelectedCheckinDetail"
            data-id="{{item.id}}"
          >
            <image wx:if="{{item.user}}" class="user-avatar-small" src="{{item.user.avatarUrl}}" mode="aspectFill" />
            <image wx:else class="user-avatar-small" src="/assets/default-avatar.png" mode="aspectFill" />
            <view class="checkin-info">
              <text wx:if="{{item.user}}" class="user-name">{{item.user.nickname}}</text>
              <text wx:else class="user-name">匿名用户</text>
              <text class="checkin-content">{{item.content || '无内容'}}</text>
            </view>
            <text class="checkin-time">{{item.createdAt}}</text>
          </view>
        </view>
      </card>
    </view>

    <!-- 打卡记录 -->
    <view class="section">
      <view class="section-header">
        <view class="section-title">打卡记录</view>
        <view class="section-tabs">
          <view class="tab {{activeTab === 'all' ? 'active' : ''}}" bind:tap="switchTab" data-tab="all">全部</view>
          <view class="tab {{activeTab === 'mine' ? 'active' : ''}}" bind:tap="switchTab" data-tab="mine">我的</view>
        </view>
      </view>

      <view wx:if="{{checkins.length === 0}}" class="empty-area">
        <empty title="暂无打卡记录" description="成为第一个打卡的人吧"></empty>
      </view>

      <view wx:else class="checkin-list">
        <checkin-card
          wx:for="{{checkins}}"
          wx:key="id"
          checkin="{{item}}"
          isOwner="{{item.userId === userId}}"
          bind:tap="goToCheckinDetail"
          bind:like="onLike"
          bind:delete="onDeleteCheckin"
        ></checkin-card>
      </view>
    </view>

    <!-- 底部操作栏 -->
    <view wx:if="{{theme.isMember}}" class="bottom-bar">
      <view class="checkin-btn {{canCheckin ? '' : 'disabled'}}" bind:tap="goToCheckin">
        <text wx:if="{{canCheckin}}">立即打卡</text>
        <text wx:else>今日已打卡</text>
      </view>
    </view>

    <view wx:else class="bottom-bar">
      <view class="checkin-btn" bind:tap="joinTheme">
        <text>加入主题</text>
      </view>
    </view>
  </view>
</view>
