<!-- 主题列表页 - 完全还原 Figma 设计稿 -->
<view class="theme-list-page">
  <!-- 顶部导航栏 -->
  <view class="header-bar" style="height: {{navBarHeight}}px; padding-top: {{statusBarHeight}}px;">
    <view class="back-icon" bind:tap="goBack">
      <view class="arrow-left"></view>
    </view>
    <view class="header-title">主题列表</view>
    <view class="header-right"></view>
  </view>

  <view class="page-content" style="padding-top: {{navBarHeight + 16}}px;">
    <!-- Tab 切换器 -->
    <view class="tab-switcher">
      <view
        class="tab-item {{activeTab === 'joined' ? 'active' : ''}}"
        bind:tap="switchTab"
        data-tab="joined"
      >
        <text>我加入的</text>
      </view>
      <view
        class="tab-item {{activeTab === 'created' ? 'active' : ''}}"
        bind:tap="switchTab"
        data-tab="created"
      >
        <text>我创建的</text>
      </view>
    </view>

    <!-- 加载状态 -->
    <view wx:if="{{loading && !themes.length}}" class="loading-area">
      <loading></loading>
    </view>

    <!-- 空状态 -->
    <view wx:elif="{{!filteredThemes.length}}" class="empty-area">
      <view class="empty-content">
        <text class="empty-title">还没有加入任何主题</text>
        <text class="empty-desc">点击右下角 + 创建或加入主题</text>
      </view>
    </view>

    <!-- 主题卡片列表 -->
    <view wx:else class="theme-grid">
      <view
        wx:for="{{filteredThemes}}"
        wx:key="id"
        class="theme-card"
        bind:tap="goToDetail"
        data-theme="{{item}}"
      >
        <!-- 卡片封面 -->
        <view class="card-cover-wrapper">
          <image
            wx:if="{{item.coverImage}}"
            class="card-cover"
            src="{{item.coverImage}}"
            mode="aspectFill"
          />
          <view wx:else class="card-cover-placeholder">
            <text class="placeholder-icon">🎯</text>
          </view>
          <!-- 类型标签 -->
          <view class="type-tag {{item.checkinType === 'rich' ? 'rich-text' : 'simple'}}">
            <text>{{item.checkinType === 'rich' ? '富文本打卡' : '简单打卡'}}</text>
          </view>
        </view>

        <!-- 卡片内容 -->
        <view class="card-content">
          <view class="card-header">
            <text class="card-title">{{item.title}}</text>
            <view class="member-count">
              <text class="member-icon">👥</text>
              <text class="member-num">{{item.memberCount || 0}}</text>
            </view>
          </view>

          <!-- 进度条 -->
          <view class="progress-section">
            <view class="progress-labels">
              <text class="progress-label">当前进度</text>
              <text class="progress-percent">{{item.progress || 0}}%</text>
            </view>
            <view class="progress-bar">
              <view class="progress-track"></view>
              <view class="progress-fill" style="width: {{item.progress || 0}}%"></view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 悬浮添加按钮 -->
  <view class="fab-button" bind:tap="goToCreateJoin">
    <text class="fab-icon">+</text>
  </view>
</view>
