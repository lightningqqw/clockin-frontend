<!-- 登录页面 -->
<view class="login-page">
  <!-- 背景装饰 -->
  <view class="bg-decoration">
    <view class="bg-blur-top"></view>
    <view class="bg-blur-bottom"></view>
  </view>

  <!-- 左上角叶子装饰 -->
  <view class="leaf-decoration">🍃</view>

  <view class="login-container">
    <!-- Logo 区域 -->
    <view class="logo-section">
      <view class="logo-wrapper">
        <view class="logo-bg">
          <view class="logo">🎯</view>
        </view>
        <view class="logo-dot"></view>
      </view>
      <view class="app-name">每日打卡</view>
      <view class="app-slogan">坚持每一天，成就更好的自己</view>
    </view>

    <!-- 登录按钮区域 -->
    <view class="login-section">
      <view wx:if="{{loading}}" class="loading-wrapper">
        <loading text="登录中..."></loading>
      </view>
      <view wx:else class="login-buttons">
        <!-- 微信登录按钮 -->
        <button
          class="wechat-login-btn"
          bind:tap="onWechatLogin"
        >
          <text class="btn-icon">💬</text>
          <text class="btn-text">微信一键登录</text>
        </button>

        <!-- 手机号登录按钮 -->
        <button
          class="phone-login-btn"
          bind:tap="onPhoneLogin"
        >
          <text class="btn-text">其他手机号登录</text>
        </button>
      </view>

      <!-- 隐私政策 -->
      <view class="privacy-section">
        <view class="checkbox-wrapper" bind:tap="toggleAgree">
          <view class="checkbox {{agreed ? 'checked' : ''}}">
            <text wx:if="{{agreed}}" class="check-icon">✓</text>
          </view>
        </view>
        <view class="privacy-text">
          <text>我已阅读并同意 </text>
          <text class="link" bind:tap="showPrivacy">用户协议</text>
          <text> 与 </text>
          <text class="link" bind:tap="showTerms">隐私政策</text>
        </view>
      </view>
    </view>
  </view>
</view>
