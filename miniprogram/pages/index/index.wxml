<!-- 首页 -->
<view class="index-page">
  <navbar title="每日打卡" showBack="{{false}}"></navbar>

  <view class="page-content">
    <!-- 用户信息卡片 -->
    <view class="user-card">
      <view class="user-info">
        <image wx:if="{{userInfo}}" class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
        <image wx:else class="user-avatar" src="/assets/default-avatar.png" mode="aspectFill" />
        <view class="user-meta">
          <view wx:if="{{userInfo}}" class="user-name">{{userInfo.nickname}}</view>
          <view wx:else class="user-name">用户</view>
          <view class="user-stats">
            <text class="stat-item">已加入 {{stats.themeCount || 0}} 个主题</text>
          </view>
        </view>
      </view>
      <view class="quick-actions">
        <view class="action-item" bind:tap="goToCreateTheme">
          <text class="action-icon">➕</text>
          <text class="action-text">创建主题</text>
        </view>
        <view class="action-item" bind:tap="goToJoinTheme">
          <text class="action-icon">🔗</text>
          <text class="action-text">加入主题</text>
        </view>
      </view>
    </view>

    <!-- 今日打卡状态 -->
    <view wx:if="{{todayThemes.length > 0}}" class="section">
      <view class="section-header">
        <view class="section-title">📅 今日打卡</view>
        <view class="section-count">{{checkedCount}}/{{todayThemes.length}}</view>
      </view>
      <view class="today-themes">
        <view
          wx:for="{{todayThemes}}"
          wx:key="id"
          class="today-theme-item {{item.hasChecked ? 'checked' : ''}}"
          bind:tap="goToCheckin"
          data-theme="{{item}}"
        >
          <view class="theme-info">
            <text class="theme-name">{{item.title}}</text>
            <text wx:if="{{item.hasChecked}}" class="check-status">✓ 已打卡</text>
            <text wx:else class="check-status pending">未打卡</text>
          </view>
          <view wx:if="{{!item.hasChecked}}" class="checkin-btn">
            <text>去打卡</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 最近动态 -->
    <view class="section">
      <view class="section-header">
        <view class="section-title">🔥 最近动态</view>
        <view class="section-more" bind:tap="refresh">刷新</view>
      </view>

      <view wx:if="{{loading && !checkins.length}}" class="loading-area">
        <loading></loading>
      </view>

      <view wx:elif="{{!checkins.length}}" class="empty-area">
        <empty title="暂无动态" description="去创建主题并开始打卡吧"></empty>
      </view>

      <view wx:else class="checkin-list">
        <checkin-card
          wx:for="{{checkins}}"
          wx:key="id"
          checkin="{{item}}"
          bind:tap="goToCheckinDetail"
          bind:like="onLike"
        ></checkin-card>
      </view>

      <!-- 加载更多 -->
      <view wx:if="{{hasMore && checkins.length > 0}}" class="load-more">
        <custom-button
          wx:if="{{!loadingMore}}"
          type="default"
          size="small"
          plain
          bind:tap="loadMore"
        >加载更多</custom-button>
        <loading wx:else></loading>
      </view>
    </view>
  </view>
</view>
