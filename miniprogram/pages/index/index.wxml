<!-- 首页 - 完全还原 Figma 设计稿 -->
<view class="index-page">
  <!-- 顶部导航栏 -->
  <view class="header-bar" style="height: {{navBarHeight}}px; padding-top: {{statusBarHeight}}px;">
    <view class="back-icon" bind:tap="goBack">
      <view class="arrow-left"></view>
    </view>
    <view class="header-title">每日打卡</view>
    <view class="header-right"></view>
  </view>

  <view class="page-content" style="padding-top: {{navBarHeight + 16}}px;">
    <!-- Hero 进度可视化卡片 -->
    <view class="hero-card">
      <view class="hero-bg-decor-top"></view>
      <view class="hero-bg-decor-bottom"></view>
      <view class="hero-content">
        <view class="progress-label">PROGRESS JOURNEY</view>
        <view class="progress-circle-wrapper">
          <view class="progress-circle">
            <view class="progress-svg">
              <view class="circle-bg"></view>
              <view class="circle-progress" style="--progress: {{progressPercent}}%"></view>
            </view>
            <view class="progress-text">
              <text class="progress-number">{{checkedCount}}/{{todayThemes.length}}</text>
              <text class="progress-sublabel">已完成</text>
            </view>
          </view>
        </view>
        <view class="motivation-text">坚持就是胜利 🌱</view>
      </view>
    </view>

    <!-- 今日打卡区域 -->
    <view class="today-section">
      <view class="section-header">
        <view class="header-left">
          <view class="section-title">📅 今日打卡</view>
          <view class="section-subtitle">Today's Rituals</view>
        </view>
        <view class="completion-badge">
          COMPLETION: {{completionRate}}%
        </view>
      </view>

      <!-- 打卡列表 -->
      <view class="habit-list">
        <view
          wx:for="{{todayThemes}}"
          wx:key="id"
          class="habit-item {{item.hasChecked ? 'completed' : ''}}"
          bind:tap="goToCheckin"
          data-theme="{{item}}"
        >
          <view class="habit-left">
            <view class="habit-icon-wrapper {{item.iconBgClass}}">
              <text class="habit-icon">{{item.icon || '📝'}}</text>
            </view>
            <view class="habit-info">
              <text class="habit-name">{{item.title}}</text>
              <view class="habit-status">
                <text wx:if="{{item.hasChecked}}" class="status-icon">✓</text>
                <text wx:else class="status-icon">⏱</text>
                <text class="status-text {{item.hasChecked ? 'completed' : 'pending'}}">
                  {{item.hasChecked ? '已打卡' : '未打卡'}}
                </text>
              </view>
            </view>
          </view>
          <view class="habit-right">
            <view wx:if="{{item.hasChecked}}" class="completed-check">
              <text class="check-icon">✓</text>
            </view>
            <view wx:else class="checkin-btn" catch:tap="goToCheckin" data-theme="{{item}}">
              <text>去打卡</text>
            </view>
          </view>
        </view>

        <!-- 空状态 -->
        <view wx:if="{{todayThemes.length === 0 && !loading}}" class="empty-habits">
          <text class="empty-text">还没有加入任何主题</text>
          <text class="empty-subtext">点击右下角 + 创建或加入主题</text>
        </view>
      </view>
    </view>

    <!-- 激励名言卡片 -->
    <view class="quote-card">
      <view class="quote-bg"></view>
      <view class="quote-content">
        <view class="quote-label">Inspiration</view>
        <view class="quote-text">
          <text>"The secret of your future is hidden</text>
          <text>in your daily routine."</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 悬浮添加按钮 -->
  <view class="fab-button" bind:tap="goToCreateJoin">
    <text class="fab-icon">+</text>
  </view>
</view>
