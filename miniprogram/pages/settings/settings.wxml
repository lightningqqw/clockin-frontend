<!-- 设置页面 -->
<view class="settings-page">
  <navbar title="设置"></navbar>

  <view class="page-content">
    <!-- 缓存管理 -->
    <card title="存储管理">
      <view class="menu-list">
        <view class="menu-item" bind:tap="clearCache">
          <text class="menu-text">清除缓存</text>
          <text class="menu-value">{{cacheSize}}</text>
        </view>
      </view>
    </card>

    <!-- 关于 -->
    <card title="关于">
      <view class="menu-list">
        <view class="menu-item" bind:tap="showAbout">
          <text class="menu-text">关于我们</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bind:tap="showPrivacy">
          <text class="menu-text">用户协议</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bind:tap="showTerms">
          <text class="menu-text">隐私政策</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
    </card>

    <!-- 版本信息 -->
    <view class="version-info">
      <text>版本 1.0.0</text>
    </view>
  </view>
</view>
