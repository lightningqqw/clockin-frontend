/* 日历组件样式 */
.calendar {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.current-month {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.nav-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 28rpx;
  font-size: 28rpx;
  color: #666;
  transition: background 0.2s;
}

.nav-btn:active {
  background: #e5e5e5;
}

.week-header {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: 16rpx;
}

.week-day {
  text-align: center;
  font-size: 26rpx;
  color: #999;
  padding: 16rpx 0;
}

.days-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.day-cell {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  transition: all 0.2s;
  position: relative;
}

.day-cell.current-month {
  background: #f8f8f8;
}

.day-cell.other-month {
  background: transparent;
  opacity: 0.4;
}

.day-cell.today {
  background: #07c160;
}

.day-cell.today .day-number {
  color: #fff;
  font-weight: 600;
}

.day-cell.has-checkin {
  background: #e6f7ed;
}

.day-cell.has-checkin.today {
  background: #07c160;
}

.day-cell.future {
  opacity: 0.6;
}

.day-cell:active {
  transform: scale(0.95);
}

.day-number {
  font-size: 28rpx;
  color: #333;
}

.checkin-indicator {
  width: 8rpx;
  height: 8rpx;
  background: #07c160;
  border-radius: 50%;
  position: absolute;
  bottom: 12rpx;
}

.day-cell.today .checkin-indicator {
  background: #fff;
}

.calendar-stats {
  display: flex;
  justify-content: space-around;
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f0f0f0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #07c160;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}
