/* 打卡卡片样式 */
.checkin-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.checkin-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  margin-right: 16rpx;
  background: #f0f0f0;
}

.user-meta {
  flex: 1;
}

.user-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.checkin-time {
  font-size: 24rpx;
  color: #999;
}

.mood-tag {
  padding: 8rpx 16rpx;
  background: #fff5e6;
  border-radius: 24rpx;
  font-size: 28rpx;
}

.checkin-content {
  margin-bottom: 20rpx;
}

.checkin-date {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.date-icon {
  margin-right: 8rpx;
}

.content-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  word-break: break-all;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 16rpx;
}

.grid-image {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 12rpx;
  object-fit: cover;
}

.checkin-location {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #576b95;
  margin-top: 16rpx;
}

.location-icon {
  margin-right: 8rpx;
}

.checkin-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f0f0;
}

.footer-left,
.footer-right {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx;
  transition: opacity 0.2s;
}

.action-btn:active {
  opacity: 0.6;
}

.action-btn.active .btn-text {
  color: #fa5151;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 26rpx;
  color: #666;
}
