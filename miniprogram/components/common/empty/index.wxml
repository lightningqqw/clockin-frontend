<!-- 空状态组件 -->
<view class="empty-container">
  <image wx:if="{{image}}" class="empty-image" src="{{image}}" mode="aspectFit" />
  <view wx:else class="empty-icon">{{icon || '📭'}}</view>
  <view class="empty-title">{{title || '暂无数据'}}</view>
  <view wx:if="{{description}}" class="empty-description">{{description}}</view>
  <slot></slot>
</view>
