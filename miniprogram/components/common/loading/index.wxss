/* 加载组件样式 */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading-container.fullscreen {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
}

.loading-container.mask {
  background: rgba(255, 255, 255, 0.9);
}

.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.spinner-dot {
  width: 16rpx;
  height: 16rpx;
  background: #07c160;
  border-radius: 50%;
  animation: bounce 1.4s ease-in-out infinite both;
}

.spinner-dot:nth-child(1) {
  animation-delay: -0.32s;
}

.spinner-dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes bounce {
  0%,
  80%,
  100% {
    transform: scale(0.6);
    opacity: 0.5;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #666;
}
